generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 枚举定义 
// ==========================================

/// 用户权限角色
enum Role {
  student // 学生
  teacher // 教师
  admin   // 管理员
}

/// 聊天消息发送方角色
enum MessageRole {
  user      // 用户
  assistant // AI 助手
  system    // 系统指令
}

/// 知识图谱节点层级
enum NodeLevel {
  LEVEL1 // 一级：课程 (Course)
  LEVEL2 // 二级：模块 (Module)
  LEVEL3 // 三级：知识点 (Knowledge Point)
  LEVEL4 // 四级：资源挂载点 (Resource Node)
}

/// 节点间的逻辑关系类型
enum RelationType {
  CONTAINS   // 包含关系 (A包含B)
  DEPENDS_ON // 依赖关系 (学B前需学A)
  SIMILAR_TO // 相似关系 (内容相关)
}

/// 资源文件类型
enum ResourceType {
  PPT
  VIDEO
  PDF
}

/// 用户学习行为埋点
enum LearningAction {
  VIEW         // 浏览
  ASK_QUESTION // 针对该点提问
  DO_EXERCISE  // 做题
  FINISH_LEARN // 完成学习
}

/// 练习题题型
enum ExerciseType {
  SINGLE_CHOICE // 单选题
  TRUE_FALSE    // 判断题
  FILL_BLANK    // 填空题
}

// ==========================================
// 模型定义
// ==========================================

model User {
  id          Int      @id @default(autoincrement())
  userName    String?  // 用户昵称/显示名
  email       String   @unique // 登录邮箱
  password    String   // 加密后的密码
  phoneNumber String?  // 联系电话
  avatarUrl   String?  // 头像地址
  bio         String?  // 个人简介
  role        Role     @default(student)

  // 身份信息
  identifier  String?  @unique // 唯一编号：学号或工号
  department  String?  // 所属院系/专业
  grade       String?  // 年级/班级
  realName    String?  // 实名信息

  // 反向关系列表
  conversations   Conversation[]   // 用户的会话历史
  learningRecords LearningRecord[] // 用户的学习进度记录
  exerciseRecords ExerciseRecord[] // 用户的做题记录
  userFiles       UserFile[]       // 用户上传的个人文件
  createdCourses  Node[]           @relation("UserCreatedNodes") // 教师创建的课程节点
  course          Node[]           @relation("UserCourses")
  ppts            PPT[]            // 用户创建的PPT

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserFile {
  id         Int      @id @default(autoincrement())
  fileName   String   // 文件原始名称
  filePath   String   @unique // 存储桶(COS/OSS)中的唯一路径
  fileSize   String?  // 文件大小描述 (如 "1.2MB")
  fileFormat String?  // 后缀名
  isFolder   Boolean  @default(false) // 是否为目录结构
  
  userId     Int      // 上传者ID
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@index([userId])
}

model Conversation {
  id     Int     @id @default(autoincrement())
  title  String? // 自动生成的会话标题
  userId Int
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages Message[] // 会话中的消息流

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    MessageRole // 消息发送方
  content String      // 消息正文 (支持Markdown)

  nodeId Int?   // 该消息是否关联了某个特定的知识节点
  node   Node?  @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([conversationId])
}

model Node {
  id                Int       @id @default(autoincrement())
  nodeName          String    // 节点/课程名称
  nodeLevel         NodeLevel // 当前层级
  description       String?   // 节点详细介绍
  order             Int       @default(0) // 同级排序权重
  estimatedDuration Int?      @default(0) // 预计学习时长 (秒)

  creatorId         Int?      // 创建者ID (通常仅LEVEL1课程节点有值)
  creator           User?     @relation("UserCreatedNodes", fields: [creatorId], references: [id], onDelete: SetNull)

  // 树形结构定义
  parentNodeId      Int?      // 父节点ID
  parentNode        Node?     @relation("NodeHierarchy", fields: [parentNodeId], references: [id], onDelete: Cascade)
  childNodes        Node[]    @relation("NodeHierarchy")

  students          User[]    @relation("UserCourses")

  resource          Resource[] // 挂载的教学资源 (1:N)
  
  messages          Message[]        // 关联的消息
  learningRecords   LearningRecord[] // 学生在该点的学习数据
  exercises         Exercise[]       // 挂载在该点的练习题

  createdAt         DateTime @default(now())
}

model Resource {
  id           Int          @id @default(autoincrement())
  resourceName String       // 资源显示名称
  resourceType ResourceType @default(PPT) // 资源类别
  resourcePath String       // 存储地址
  fileSize     String?      // 文件大小
  fileFormat   String?      // 文件扩展名

  nodeId Int // 归属的知识节点ID
  node   Node @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nodeId])
}

model LearningRecord {
  id          Int            @id @default(autoincrement())
  userId      Int
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodeId      Int
  node        Node           @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  actionType  LearningAction // 行为类型
  duration    Int?           @default(0)     // 本次停留/学习时长
  isCompleted Boolean        @default(false) // 是否标记为学完
  
  createdAt   DateTime       @default(now())

  @@index([userId, nodeId])
}

model Exercise {
  id              Int          @id @default(autoincrement())
  exerciseTitle   String?      // 题目简述
  exerciseContent String       // 题目正文
  type            ExerciseType // 题型
  score           Int          @default(10) // 题目分值
  blankAnswer     String?      // 填空题的标准答案 (若是单选则存储在ExerciseOption中)

  nodeId Int // 关联知识点
  node   Node @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  options ExerciseOption[] // 题目选项 (单选/判断用)
  records ExerciseRecord[] // 学生答题历史

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExerciseOption {
  id         Int      @id @default(autoincrement())
  exerciseId Int
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  content   String  // 选项描述内容
  isCorrect Boolean @default(false) // 是否是正确选项

  exerciseRecords ExerciseRecord[] // 选过此项的记录

  createdAt DateTime @default(now())
}

model ExerciseRecord {
  id       Int  @id @default(autoincrement())
  userId   Int
  user     User @relation(fields: [userId], references: [id], onDelete: Cascade)

  exerciseId Int
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  selectedOptionId Int? // 学生选择的选项ID (单选/判断)
  selectedOption   ExerciseOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  blankAnswer String?  // 学生输入的填空内容 (填空题)
  isCorrect   Boolean? // 系统自动判定结果
  score       Int?     // 本次得分

  createdAt DateTime @default(now())

  @@index([userId, exerciseId])
}

model PPT {
  id          Int      @id @default(autoincrement())
  title       String   // PPT标题
  description String?  // PPT描述
  pptUrl      String   // 星火模型返回的PPT URL链接
  userId      Int      // 创建者用户ID
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  
  @@index([userId])
}
